# Copy this file to `.env` (which is gitignored) and fill in your real values.
# NEVER commit real secrets. These are read from the environment by the HF /
# W&B libraries automatically; nothing in this repo hardcodes them.

# Hugging Face token (write scope to upload, read scope to download private/gated).
# Create at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Weights & Biases API key (only if you wire up W&B logging).
# Create at: https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_key_here
